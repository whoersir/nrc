# CloudBase 环境变量配置模板
# 复制此文件为 .env.local 并填入实际值

# ⚠️ 安全提示：
# - 所有敏感信息必须从环境变量读取，禁止硬编码
# - 生产环境使用强密码和安全的 API keys
# - 定期轮换密钥

# CloudBase 环境配置
TCB_ENV_ID=wxg-8gafv6m97fd71cde
TCB_REGION=ap-shanghai

# 服务器端认证（用于 Node.js SDK）
TCB_SECRET_ID=your_secret_id_here
TCB_SECRET_KEY=your_secret_key_here

# 应用配置
NEXT_PUBLIC_APP_URL=http://localhost:5000
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# ⚠️ 必需：Knot Chat API 配置
# 从 Knot Chat 平台获取，不要硬编码在代码中
KNOT_API_TOKEN=your_knot_api_token_here
NEXT_PUBLIC_KNOT_API_BASE=https://knot.woa.com/apigw/api/v1/agents/agui/your_agent_id

# Supabase 环境配置（必需）
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ⚠️ 可选：CORS 配置
# 生产环境限制允许的来源，用逗号分隔
# CORS_ALLOWED_ORIGINS=https://your-domain.com,https://another-domain.com

# 日志配置（生产环境建议设为 info 或 warn）
LOG_LEVEL=debug
